{
  "name": "tradumust",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 1234",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "backend": "php -S 127.0.0.1:8000 -t api/public api/router.php",
    "backend:python": "uvicorn backend.main:app --reload --port 8000",
    "test": "node --test tests/unit/sign-mapper.test.js tests/unit/vocab-10k.test.js tests/unit/signer2d.test.js",
    "test:ext": "node --test tests/unit/sign-mapper.test.js tests/unit/vocab-10k.test.js tests/unit/signer2d.test.js",
    "test:backend": ".venv/Scripts/python -m pytest tests/backend/ -v",
    "test:ml": ".venv/Scripts/python -m pytest tests/ml/ -v",
    "test:load": ".venv/Scripts/python -m pytest tests/load/ -v",
    "test:perf": "node --test tests/perf/sign-mapper.perf.js",
    "test:integration": "node --test tests/integration/pipeline.test.js",
    "test:stress": "node --test tests/stress/sign-mapper.stress.js",
    "test:all": "node --test tests/unit/sign-mapper.test.js tests/unit/vocab-10k.test.js tests/unit/signer2d.test.js tests/perf/sign-mapper.perf.js tests/integration/pipeline.test.js tests/stress/sign-mapper.stress.js && .venv/Scripts/python -m pytest tests/backend/ tests/ml/ tests/load/ -v"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.34",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "lucide-react": "^1.7.0",
    "next": "^14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "three": "^0.165.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/three": "^0.165.0",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
