{
  "name": "tradumust",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 1234",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "backend": ".venv\\Scripts\\python.exe -m uvicorn backend.main:app --reload --port 8001",
    "backend:python": ".venv\\Scripts\\python.exe -m uvicorn backend.main:app --reload --port 8001",
    "test": "node --test tests/unit/sign-mapper.test.js tests/unit/vocab-10k.test.js tests/unit/signer2d.test.js",
    "test:ext": "node --test tests/unit/sign-mapper.test.js tests/unit/vocab-10k.test.js tests/unit/signer2d.test.js",
    "test:backend": ".venv\\Scripts\\python -m pytest tests/backend/test_api.py -v",
    "test:security": ".venv\\Scripts\\python -m pytest tests/backend/test_security.py -v",
    "test:contracts": ".venv\\Scripts\\python -m pytest tests/backend/test_contracts.py -v",
    "test:ml": ".venv\\Scripts\\python -m pytest tests/ml/ -v",
    "test:load": ".venv\\Scripts\\python -m pytest tests/load/ -v",
    "test:perf": "npm run test:k6:load",
    "test:dynamic": "node --test tests/dynamic/dynamic.test.js",
    "test:integration": "node --test tests/integration/pipeline.test.js",
    "test:stress": "npm run test:k6:stress",
    "test:soak": "npm run test:k6:soak",
    "test:spike": "npm run test:k6:spike",
    "test:smoke": "npm run test:k6:smoke",
    "test:k6:smoke": "k6 run tests/k6/k6-smoke.js",
    "test:k6:load": "k6 run tests/k6/k6-load.js",
    "test:k6:stress": "k6 run tests/k6/k6-stress.js",
    "test:k6:spike": "k6 run tests/k6/k6-spike.js",
    "test:k6:soak": "k6 run tests/k6/k6-soak.js",
    "test:k6:dynamic": "k6 run tests/k6/k6-dynamic.js",
    "test:all": ".venv\\Scripts\\python tests/run_all_tests.py",
    "test:all:fast": ".venv\\Scripts\\python tests/run_all_tests.py --fast",
    "sonar:coverage": "rm -rf coverage/tmp && mkdir -p coverage/tmp && cross-env NODE_V8_COVERAGE=coverage/tmp node --test tests/unit/sign-mapper.test.js tests/unit/vocab-10k.test.js && npx c8 report --temp-directory coverage/tmp --reporter=lcov --include=\"extension/content/**\" --exclude=\"extension/content/vocab-10k.js\" --all",
    "sonar:scan": "node sonar-scan.js",
    "sonar": "npm run sonar:coverage && npm run sonar:scan"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.34",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@types/canvas-confetti": "^1.9.0",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "next": "^14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "tailwind-merge": "^3.5.0",
    "three": "^0.165.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/three": "^0.165.0",
    "autoprefixer": "^10.0.1",
    "c8": "^11.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^8",
    "eslint-config-next": "^14.2.0",
    "fast-check": "^4.6.0",
    "postcss": "^8",
    "sonarqube-scanner": "^4.3.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
